APP_NAME=MyDualist
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://mydualist.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=redis

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mydualist
DB_USERNAME=root
DB_PASSWORD=

# WordPress source database (for php artisan blog:import --database)
WP_DB_HOST=127.0.0.1
WP_DB_PORT=3306
WP_DB_DATABASE=
WP_DB_USERNAME=root
WP_DB_PASSWORD=
WP_DB_PREFIX=wp_

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=mydualist_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@mydualist.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MYDUALIST_NAME="${APP_NAME}"
MYDUALIST_LOGO_URL=images/logo-mdl.svg
MYDUALIST_TEST_OTP=0000
# MYDUALIST_PREMIUM_PRICE=12.99
# MYDUALIST_PREMIUM_CURRENCY=gbp
# MYDUALIST_STRIPE_SUCCESS_URL=
# MYDUALIST_STRIPE_CANCEL_URL=
# Mobile deep links example:
# MYDUALIST_STRIPE_SUCCESS_URL=mydualist://billing/success?session_id={CHECKOUT_SESSION_ID}
# MYDUALIST_STRIPE_CANCEL_URL=mydualist://billing/cancel

# Twilio WhatsApp (submission OTP + completion notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_FROM=
TWILIO_OTP_TEMPLATE_SID=
TWILIO_COMPLETION_TEMPLATE_SID=
TWILIO_SALAWAT_TEMPLATE_SID=
TWILIO_TEST_OTP=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Billing monitoring (Phase 9)
# MYDUALIST_BILLING_UNFULFILLED_ALERT_THRESHOLD=5
# MYDUALIST_BILLING_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/...

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,mydualist.test,mydualist-laravel.test
